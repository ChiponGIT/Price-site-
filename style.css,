:root{
  --bg:#0b0f17;
  --card:#111827;
  --muted:#94a3b8;
  --text:#e5e7eb;
  --line:#1f2937;
  --accent:#60a5fa;
  --good:#22c55e;
}

*{box-sizing:border-box}
body{
  margin:0;
  font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial;
  background: radial-gradient(1200px 800px at 20% 10%, #0f1b3a 0%, var(--bg) 55%);
  color:var(--text);
}

.top{
  padding:28px 18px 10px;
  border-bottom:1px solid var(--line);
}
.top h1{margin:0;font-size:28px;letter-spacing:.2px}
.sub{margin:6px 0 0;color:var(--muted)}

.wrap{max-width:1000px;margin:0 auto;padding:18px;display:grid;gap:14px}

.card{
  background: linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
  border:1px solid var(--line);
  border-radius:16px;
  padding:14px;
  box-shadow: 0 10px 30px rgba(0,0,0,.25);
}

.cardHead{margin-bottom:10px}
.cardHead h2{margin:0;font-size:18px}
.hint{margin:6px 0 0;color:var(--muted);font-size:13px}

.form{
  display:grid;
  grid-template-columns: 1.2fr .8fr .6fr 1.2fr auto;
  gap:10px;
}
@media (max-width: 860px){
  .form{grid-template-columns:1fr; }
}

.input, .select{
  width:100%;
  padding:10px 12px;
  background:#0b1220;
  border:1px solid var(--line);
  border-radius:12px;
  color:var(--text);
  outline:none;
}
.input:focus, .select:focus{border-color:rgba(96,165,250,.7); box-shadow:0 0 0 3px rgba(96,165,250,.15);}

.btn{
  padding:10px 14px;
  border-radius:12px;
  border:1px solid rgba(96,165,250,.35);
  background: rgba(96,165,250,.18);
  color:var(--text);
  cursor:pointer;
}
.btn:hover{background: rgba(96,165,250,.26)}
.btn.ghost{
  background: transparent;
  border:1px solid var(--line);
}
.btn.ghost:hover{background: rgba(255,255,255,.06)}

.row{display:flex;align-items:flex-start;justify-content:space-between;gap:12px}
.controls{display:flex;gap:10px;align-items:center;flex-wrap:wrap}

.grid{
  display:grid;
  grid-template-columns: repeat(3, minmax(0,1fr));
  gap:10px;
}
@media (max-width: 900px){ .grid{grid-template-columns:1fr} }

.item{
  border:1px solid var(--line);
  background:#0b1220;
  border-radius:14px;
  padding:12px;
  display:flex;
  flex-direction:column;
  gap:8px;
  position:relative;
}
.badge{
  position:absolute;
  top:10px;
  right:10px;
  font-size:12px;
  padding:4px 8px;
  border-radius:999px;
  border:1px solid rgba(34,197,94,.35);
  background: rgba(34,197,94,.12);
  color: #bbf7d0;
}

.title{font-weight:700}
.meta{display:flex;gap:8px;flex-wrap:wrap;color:var(--muted);font-size:13px}
.price{font-size:22px;font-weight:800}
.link{color:var(--accent);text-decoration:none}
.link:hover{text-decoration:underline}

.foot{
  padding:18px;
  color:var(--muted);
  text-align:center;
}
